# Copiar a .env y rellenar (no subir .env al repositorio)
NODE_ENV=development

PORT=4000
HOST=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=arthome_db
DB_SCHEMA=arthome

JWT_SECRET=
JWT_EXPIRES_IN=1h

# Si es true, exige todas las variables críticas aunque NODE_ENV no sea production
# REQUIRE_FULL_ENV=false

# --- Almacenamiento de imágenes (factor IV: backing service sustituible) ---
# local = disco (IMAGE_STORAGE_LOCAL_ROOT relativo a la raíz del proyecto o ruta absoluta)
# cdn = manifiesto JSON remoto (IMAGE_MANIFEST_URL) + URLs absolutas o files + IMAGE_PUBLIC_BASE_URL
STORAGE_PROVIDER=local
IMAGE_STORAGE_LOCAL_ROOT=public/images

# Ejemplo CDN (producción): subir manifest.json a tu bucket/CDN y apuntar la URL:
# STORAGE_PROVIDER=cdn
# IMAGE_MANIFEST_URL=https://tu-cdn.com/arthome/images-manifest.json
# IMAGE_PUBLIC_BASE_URL=https://tu-cdn.com
