{
  "info": {
    "name": "ArtHome API - Automated",
    "_postman_id": "7b9d3c4e-arthome-api-automated",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health (GET productos)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const productos = json.productos ?? json;",
              "pm.test('Devuelve productos (array)', function () {",
              "  pm.expect(productos).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/productos",
          "host": ["{{baseUrl}}"],
          "path": ["api", "productos"]
        }
      }
    },
    {
      "name": "02 - Login (JWT)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const email = pm.environment.get('email');",
              "const pass = pm.environment.get('contrasena');",
              "if (!email || !pass) {",
              "  console.log('Sin credenciales en environment: se omiten aserciones de login.');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const email = pm.environment.get('email');",
              "const pass = pm.environment.get('contrasena');",
              "if (!email || !pass) {",
              "  pm.test('Login omitido (sin credenciales en environment)', function () { pm.expect(true).to.eql(true); });",
              "  return;",
              "}",
              "",
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Devuelve accessToken', function () {",
              "  pm.expect(json).to.have.property('accessToken');",
              "  pm.expect(json.accessToken).to.be.a('string');",
              "});",
              "pm.test('Devuelve refreshToken', function () {",
              "  pm.expect(json).to.have.property('refreshToken');",
              "  pm.expect(json.refreshToken).to.be.a('string');",
              "});",
              "",
              "pm.environment.set('token', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"contrasena\": \"{{contrasena}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "login"]
        }
      }
    },
    {
      "name": "03 - Login inválido (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"noexiste+postman@example.com\",\n  \"contrasena\": \"incorrecta\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "login"]
        }
      }
    }
  ]
}

